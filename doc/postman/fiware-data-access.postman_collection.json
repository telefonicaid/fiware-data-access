						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": \"{{daId}}\",\n    \"description\": \"Filter the animals by name, breed and time.\",\n    \"query\": \"SELECT * WHERE animalname = $animalname AND timeinstant = $timeinstant AND activity = $activity;\",\n    \"params\": [\n        {\n            \"name\": \"timeinstant\", \n            \"type\": \"DateTime\",\n            \"default\": \"2020-08-17T18:25:28.332+01:00\"\n        },\n        {\n            \"name\": \"animalname\", \n            \"type\": \"Text\",\n            \"enum\": [\"TUNA\", \"Bandolera\"]\n        },\n        {\n            \"name\": \"activity\",\n            \"required\": true,\n            \"type\": \"Number\",\n            \"default\": 16,\n            \"range\": [10, 14] \n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{url}}/{{visibility}}/fdas/{{fdaId}}/das",
